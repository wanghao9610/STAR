# Machine-specific settings. Copy and edit locally:
#   cp .env.example .env
#
# The runtime is selected by PYTHON_HOME. Either set it directly and leave
# CONDA_HOME / ENV_NAME empty, or leave it empty and let CONDA_HOME + ENV_NAME
# derive it as $CONDA_HOME/envs/$ENV_NAME. An explicit PYTHON_HOME always wins.
CODE_NAME=YOUR_CODE_NAME
ENV_NAME=YOUR_ENV_NAME
CONDA_HOME=YOUR_CONDA_HOME
PYTHON_HOME=YOUR_PYTHON_HOME

# Optional. How much the STAR skills ask before deciding (workflow conventions
# §7.7): low = take the recommended option on judgment calls and log it;
# medium = ask as documented (default); high = confirm item by item. Hard
# gates — the STOP line, commits, deletions — are asked at every level.
INVOLVE_LEVEL=medium